rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read access for all collections
    match /{document=**} {
      allow read: if true;
    }
    
    // Helper: check if current user is one of the three admins
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'giuseppeneri2323@gmail.com' ||
        request.auth.token.email == 'itztizpixel@gmail.com' ||
        request.auth.token.email == 'francesca.gucciardi8@gmail.com'
      );
    }

    // Admins collection - only admins can read/write
    match /admins/{userId} {
      allow read, write: if isAdmin();
    }
    
    // Contacts collection - admins can write, public can read
    match /contacts/{contactId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // About collection - admins can write, public can read
    match /about/{aboutId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Home collection - admins can write, public can read
    match /home/{homeId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Events collection - admins can write, public can read
    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Works collection - admins can write, public can read
    match /works/{workId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Photos collection - admins can write, public can read
    match /photos/{photoId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Products collection - admins can write, public can read
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
