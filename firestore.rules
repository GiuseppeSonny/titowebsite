rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read access to all collections for authenticated users
    match /{document=**} {
      allow read: if request.auth != null;
    }
    
    // Admins collection - only admins can read/write
    match /admins/{userId} {
      allow read, write: if request.auth != null && (request.auth.token.email == 'giuseppeneri2323@gmail.com' || request.auth.token.email == 'itztizpixel@gmail.com' || request.auth.token.email == 'Saddsadd@gmail.com');
    }
    
    // Contacts collection - admins can write, anyone can read
    match /contacts/{contactId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.token.email == 'giuseppeneri2323@gmail.com' || request.auth.token.email == 'itztizpixel@gmail.com' || request.auth.token.email == 'Saddsadd@gmail.com');
    }
    
    // About collection - admins can write, anyone can read
    match /about/{aboutId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.token.email == 'giuseppeneri2323@gmail.com' || request.auth.token.email == 'itztizpixel@gmail.com' || request.auth.token.email == 'Saddsadd@gmail.com');
    }
    
    // Home collection - admins can write, anyone can read
    match /home/{homeId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.token.email == 'giuseppeneri2323@gmail.com' || request.auth.token.email == 'itztizpixel@gmail.com' || request.auth.token.email == 'Saddsadd@gmail.com');
    }
    
    // Events collection - admins can write, anyone can read
    match /events/{eventId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.token.email == 'giuseppeneri2323@gmail.com' || request.auth.token.email == 'itztizpixel@gmail.com' || request.auth.token.email == 'Saddsadd@gmail.com');
    }
    
    // Works collection - admins can write, anyone can read
    match /works/{workId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.token.email == 'giuseppeneri2323@gmail.com' || request.auth.token.email == 'itztizpixel@gmail.com' || request.auth.token.email == 'Saddsadd@gmail.com');
    }
    
    // Photos collection - admins can write, anyone can read
    match /photos/{photoId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.token.email == 'giuseppeneri2323@gmail.com' || request.auth.token.email == 'itztizpixel@gmail.com' || request.auth.token.email == 'Saddsadd@gmail.com');
    }
    
    // Products collection - admins can write, anyone can read
    match /products/{productId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.token.email == 'giuseppeneri2323@gmail.com' || request.auth.token.email == 'itztizpixel@gmail.com' || request.auth.token.email == 'Saddsadd@gmail.com');
    }
  }
}
