rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper: check if current user is one of the three admins
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'giuseppeneri2323@gmail.com' ||
        request.auth.token.email == 'itztizpixel@gmail.com' ||
        request.auth.token.email == 'francesca.gucciardi8@gmail.com'
      );
    }

    // Videos folder - admins can read/write, authenticated users can read
    match /videos/{fileName} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Images folder - admins can read/write, authenticated users can read
    match /images/{fileName} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Photos folder - kept for backward compatibility
    match /photos/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Products folder - admins can read/write, public can read
    match /products/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Works folder - admins can read/write, public can read
    match /works/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
